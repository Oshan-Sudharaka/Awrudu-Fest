# ── AwruduFest 2026 · Environment Variables ──────────────────────────────────
# Copy this file and rename to .env  (never commit .env to git!)

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
# 1. https://cloud.mongodb.com ෙව් login වෙන්න
# 2. Cluster ➜ Connect ➜ "Connect your application" ➜ Copy connection string
# 3. <password> ෙව් ඔයාගේ DB password දාන්න
# 4. <dbname> ෙව් awrudufest දාන්න
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/awrudufest?retryWrites=true&w=majority

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── JWT Secret (strong random string දාන්න) ───────────────────────────────────
JWT_SECRET=awrudufest-CHANGE-THIS-TO-SOMETHING-RANDOM-2026

# ── CORS (deploy කළාට පස්සෙ ඔයාගේ domain දාන්න) ──────────────────────────────
# FRONTEND_URL=https://awrudufest.lk

# ── Railway / Render self-ping (auto-fill වෙනවා deploy ෙව්) ───────────────────
# RAILWAY_STATIC_URL=your-app.railway.app
# RENDER_EXTERNAL_URL=https://your-app.onrender.com
